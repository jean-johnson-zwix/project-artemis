# Database
DATABASE_URL=postgresql://user:password@localhost:5433/hackazona

# Azure OpenAI — required for Layer 2 (embeddings) and Layer 3 (reasoning)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# MS Teams Incoming Webhook
TEAMS_WEBHOOK_URL=https://...

# Discord — bot token enables thread creation and interactive Q&A
# Get token: discord.com/developers/applications → your app → Bot → Token
DISCORD_BOT_TOKEN=
# Channel ID to post alerts into (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=
# Fallback webhook (used when bot token is absent — no thread support)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Frontend base URL (used to build deep links in Teams messages)
FRONTEND_BASE_URL=http://localhost:3000
