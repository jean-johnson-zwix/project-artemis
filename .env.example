# ---------------------------------------------------------------------------
# Artemis — single source of truth for all environment variables
#
# Usage:
#   cp .env.example .env
#   fill in your values, then either:
#     docker compose up          (Docker — all services read this automatically)
#     make setup && make dev     (local dev — symlinks .env into each service dir)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# PostgreSQL
# Defaults match the docker-compose.yml and local Docker setup.
# Change these if you're connecting to a remote or differently-named database.
# ---------------------------------------------------------------------------
POSTGRES_USER=hackazona
POSTGRES_PASSWORD=hackazona
POSTGRES_DB=hackazona

# Local dev (non-Docker): points to the Docker-mapped port on localhost
# Docker: DATABASE_URL is constructed from POSTGRES_* by docker-compose.yml
DATABASE_URL=postgresql://hackazona:hackazona@localhost:5433/hackazona

# ---------------------------------------------------------------------------
# OpenAI — required for Knowledge Chat RAG (/knowledge page in the frontend)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Azure OpenAI — required for Layer 2 (embeddings) and Layer 3 (reasoning)
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# ---------------------------------------------------------------------------
# MS Teams Incoming Webhook (optional — alerts sent here on detection/resolve)
# ---------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=https://...

# ---------------------------------------------------------------------------
# Discord (required only when running the bot — docker compose --profile discord up)
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ---------------------------------------------------------------------------
# Deep-link base URL included in Teams/Discord notification cards
# ---------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:3000
